
# --------dark/light --------
map <C-i> recolor
# Enable inversion (dark mode) by default
set recolor true
set recolor-lightcolor "#282828"
set recolor-darkcolor  "#FFFFFF"
set recolor-keephue true
#enable thise 1st
set smooth-scroll true
set scroll-page-aware true
set scroll-step 50
#working on smoothness
unmap <c-up>
unmap <c-down>
#THEN
map Up scroll up
map Down scroll down

